{
  "name": "@rationalthinker1/eft-generator",
  "version": "8.0.1",
  "description": "Formats Electronic Funds Transfer (EFT) data into the CPA 005 standard.",
  "keywords": [
    "banking",
    "eft",
    "electronic-funds-transfer",
    "cpa-005"
  ],
  "homepage": "https://github.com/rationalthinker1/node-eft-generator#readme",
  "bugs": {
    "url": "https://github.com/rationalthinker1/node-eft-generator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rationalthinker1/node-eft-generator.git"
  },
  "license": "MIT",
  "author": "rationalthinker1",
  "contributors": [
    "The Corporation of the City of Sault Ste. Marie (original author)"
  ],
  "type": "module",
  "types": "./build/index.d.ts",
  "exports": {
    ".": "./build/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "imports": {
    "#BankPADInformation": {
      "development": {
        "types": "./src/domain/BankPADInformation.ts",
        "default": "./build/domain/BankPADInformation.js"
      },
      "types": "./build/domain/BankPADInformation.d.ts",
      "default": "./build/domain/BankPADInformation.js"
    },
    "#EFTFileBuilder": {
      "development": {
        "types": "./src/EFTFileBuilder.ts",
        "default": "./build/EFTFileBuilder.js"
      },
      "types": "./build/EFTFileBuilder.d.ts",
      "default": "./build/EFTFileBuilder.js"
    },
    "#EFTFileValidator": {
      "development": {
        "types": "./src/EFTFileValidator.ts",
        "default": "./build/EFTFileValidator.js"
      },
      "types": "./build/EFTFileValidator.d.ts",
      "default": "./build/EFTFileValidator.js"
    },
    "#Field": {
      "development": {
        "types": "./src/records/Field.ts",
        "default": "./build/records/Field.js"
      },
      "types": "./build/records/Field.d.ts",
      "default": "./build/records/Field.js"
    },
    "#Header": {
      "development": {
        "types": "./src/records/Header.ts",
        "default": "./build/records/Header.js"
      },
      "types": "./build/records/Header.d.ts",
      "default": "./build/records/Header.js"
    },
    "#Logger": {
      "development": {
        "types": "./src/utils/Logger.ts",
        "default": "./build/utils/Logger.js"
      },
      "types": "./build/utils/Logger.d.ts",
      "default": "./build/utils/Logger.js"
    },
    "#Segment": {
      "development": {
        "types": "./src/records/Segment.ts",
        "default": "./build/records/Segment.js"
      },
      "types": "./build/records/Segment.d.ts",
      "default": "./build/records/Segment.js"
    },
    "#Trailer": {
      "development": {
        "types": "./src/records/Trailer.ts",
        "default": "./build/records/Trailer.js"
      },
      "types": "./build/records/Trailer.d.ts",
      "default": "./build/records/Trailer.js"
    },
    "#Transaction": {
      "development": {
        "types": "./src/records/Transaction.ts",
        "default": "./build/records/Transaction.js"
      },
      "types": "./build/records/Transaction.d.ts",
      "default": "./build/records/Transaction.js"
    },
    "#types": {
      "development": {
        "types": "./src/domain/types.ts",
        "default": "./build/domain/types.js"
      },
      "types": "./build/domain/types.d.ts",
      "default": "./build/domain/types.js"
    },
    "#utils": {
      "development": {
        "types": "./src/utils/index.ts",
        "default": "./build/utils/index.js"
      },
      "types": "./build/utils/index.d.ts",
      "default": "./build/utils/index.js"
    },
    "#*": {
      "development": {
        "types": "./src/*.ts",
        "default": "./build/*.js"
      },
      "types": "./build/*.d.ts",
      "default": "./build/*.js"
    }
  },
  "files": [
    "build/index.*",
    "build/EFTFileBuilder.*",
    "build/EFTFileValidator.*",
    "build/domain/",
    "build/records/",
    "build/utils/"
  ],
  "scripts": {
    "build": "tsc",
    "build:tests": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "format": "prettier --write '{src,tests}/**/*.ts'",
    "format:check": "prettier --check '{src,tests}/**/*.ts'",
    "typecheck": "tsc -p tsconfig.test.typecheck.json",
    "prepublishOnly": "yarn build",
    "coverage": "yarn build && yarn build:tests && c8 --reporter=lcov --reporter=text --reporter=text-summary node --test \"build/tests/**/*.js\"",
    "test": "yarn build && yarn build:tests && node --test \"build/tests/**/*.js\""
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.0.13",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
