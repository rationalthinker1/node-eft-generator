{
  "name": "@rationalthinker1/eft-generator",
  "version": "2.1.0",
  "description": "Formats Electronic Funds Transfer (EFT) data into the CPA 005 standard.",
  "keywords": [
    "banking",
    "eft",
    "electronic-funds-transfer",
    "cpa-005"
  ],
  "homepage": "https://github.com/rationalthinker1/node-eft-generator#readme",
  "bugs": {
    "url": "https://github.com/rationalthinker1/node-eft-generator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rationalthinker1/node-eft-generator.git"
  },
  "license": "MIT",
  "author": "rationalthinker1",
  "contributors": [
    "The Corporation of the City of Sault Ste. Marie (original author)"
  ],
  "type": "module",
  "types": "./build/index.d.ts",
  "exports": {
    ".": "./build/index.js"
  },
  "imports": {
    "#*": {
      "development": {
        "types": "./src/*.ts",
        "default": "./build/*.js"
      },
      "types": "./build/*.d.ts",
      "default": "./build/*.js"
    }
  },
  "files": [
    "build/index.*",
    "build/types.*",
    "build/EFTFileBuilder.*",
    "build/EFTFileValidator.*",
    "build/EFTFileGenerator.*",
    "build/utils.*",
    "build/cpaCodes/"
  ],
  "scripts": {
    "build": "tsc",
    "build:tests": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "format": "prettier --write '{src,tests}/**/*.ts'",
    "format:check": "prettier --check '{src,tests}/**/*.ts'",
    "typecheck": "tsc -p tsconfig.test.typecheck.json",
    "prepublishOnly": "yarn build",
    "coverage": "yarn build && yarn build:tests && c8 --reporter=lcov --reporter=text --reporter=text-summary node --test \"build/tests/**/*.js\"",
    "test": "yarn build && yarn build:tests && node --test \"build/tests/**/*.js\""
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.0.13",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
